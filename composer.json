{
	"name": "matraux/php-code-style",
	"description": "A PHP 7.4+ library providing reusable PHP-CS-Fixer rules and shared code style configuration.",
	"keywords": ["PHP Code Style", "php-code-style", "PHP-CS-Fixer", "coding-standard", "MATRAUX"],
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Daniel Žůrek",
			"email": "info@danielzurek.cz",
			"homepage": "https://www.matraux.com"
		}
	],
	"require": {
		"php": "^7.4 || ^8.0",
		"friendsofphp/php-cs-fixer": "^3.95"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1"
	},
	"autoload": {
		"psr-4": {
			"Matraux\\PhpCodeStyle\\": "src"
		}
	},
	"support": {
		"issues": "https://github.com/matraux/php-code-style/issues",
		"source": "https://github.com/matraux/php-code-style"
	},
	"scripts": {
		"cs:check": "php-cs-fixer check --diff --using-cache no",
		"cs:fix": "php-cs-fixer fix --using-cache no",
		"phpstan": "phpstan analyse --ansi"
	},
	"scripts-descriptions": {
		"cs:check": "Check code style",
		"cs:fix": "Fix code style",
		"phpstan": "Static code analysis"
	}
}
